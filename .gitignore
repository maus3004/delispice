# ── OS / editor cruft ────────────────────────────────────────────────
**/.DS_Store
/.vscode/
*.Rhistory

# ── Python ───────────────────────────────────────────────────────────
/.venv
**/__pycache__/
**/*.pyc

# ── data_pipeline: keep the pipeline SCRIPTS, ignore all the DATA ──────
# The data dirs (data/ 9 GB, clean/ 6 GB, wbaserunners/ 6 GB) + logs move
# box-to-box out of band (rsync), NEVER via git. So ignore everything under
# data_pipeline/ by default, then re-include only the scripts + small refs.
/data_pipeline/*
!/data_pipeline/*.py
!/data_pipeline/re_matrices/
# heights.csv is intentionally NOT tracked — it's mutable scraped data each machine
# appends to (the box runs its own scraper). Sync by rsync if ever needed, like the parquet.

# ── Model artifacts (~10 MB per level-year; rebuild anywhere with
#    `python -m backend.models.cq_store` — the data is already on each box) ─
/backend/models/artifacts/

# ── App: cached picker index + user retags/clusters (rebuildable/local) ─
# .cache holds the derived parquet indexes (rebuilt on first run) plus
# autocluster.json / retags.json (your edits). To carry the edits to a new
# box, copy the .json files by hand — see deploy/DEPLOY.md.
/delispice_app/.cache/

# ── App: generated double-click launcher bundle (Mac desktop only) ──────
/delispice_app.app/

# ── Superseded / local-only material (kept on disk, out of git) ─────────
/backend/research/
/written scouting reports (practice)/
/.claude/
